# Copy to .env and fill in values before running locally

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://marketplace:marketplace@db/marketplace

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Business rules
ORDER_RATE_LIMIT_MINUTES=1

# Debug (set to true for SQL query logging)
DEBUG=false
